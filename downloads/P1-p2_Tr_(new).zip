        <script>
    var seconds = 5;
    var started = false;
    function display()
    {
        $('.btn-free-element').hide();
        $('.download-timer').show();
        if (seconds == 0)
        {
            $('.download-timer').html("<a class='btn' href='https://upxfile.com/30Qx?pt=SGdhUjd6S1BaVHdOaExsTDljWHdnSEpGUlRkcGFUZDZjMUppTmk5RWRtbElZV1Z5YVZFOVBRPT0%3D'><span class='btn__text'>DOWNLOAD / VIEW NOW</span></a>");
        } else
        {
            $('.download-timer-seconds').html(seconds);
        }
        seconds--;
    }
    
    function triggerFreeDownload() {
        if(started === true) {
            return;
        }
        
        started = true;
        display();
        countdownTimer = setInterval('display()', 1000);
    }

